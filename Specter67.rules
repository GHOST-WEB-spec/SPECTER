
(rules PCB Specter_Final.dsn
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout off)
    (autoroute on)
    (postroute off)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 1)
    (layer_rule F.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.7)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.3)
    )
  )
  (rule
    (width 400.0)
    (clearance 200.2)
    (clearance 200.0 (type smd_to_turn_gap))
    (clearance 50.0 (type smd))
    (clearance 200.2 (type "kicad_default"))
  )
  (padstack "Via[0-1]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_600:300_um" "Via[0-1]_600:300_um" default
  )
  (via 
    "Via[0-1]_600:300_um-kicad_default" "Via[0-1]_600:300_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_600:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_600:300_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    "/IR_LED" VCC GND /CS /RST /DC /MOSI /SCK
    /VBUS /MISO /GPIO4 /GPIO32 /GPIO33 /GPIO34 /GPIO35 /GPIO15
    "unconnected-(U2-EN-Pad3)" "unconnected-(U2-SENSOR_VP-Pad4)" "unconnected-(U2-SENSOR_VN-Pad5)" "unconnected-(J5-Pin_6-Pad6)" /GDO0 /BAT "/CC1101_CS" "unconnected-(U2-SHD{slash}SD2-Pad17)"
    "unconnected-(U2-SWP{slash}SD3-Pad18)" "unconnected-(U2-SCS{slash}CMD-Pad19)" "unconnected-(U2-SCK{slash}CLK-Pad20)" "unconnected-(U2-SDO{slash}SD0-Pad21)" "unconnected-(U2-SDI{slash}SD1-Pad22)" "unconnected-(U2-IO2-Pad24)" "unconnected-(U2-IO0-Pad25)" /GDO2
    "/NFC_CS" /CHRG "/RDM_TX" "unconnected-(U2-NC-Pad32)" "unconnected-(U2-RXD0{slash}IO3-Pad34)" "unconnected-(U2-TXD0{slash}IO1-Pad35)" "/RDM_RX" /STDBY
    "/SD_CS" "/GPS_TX" "/GPS_RX" "/CC1101_CS2"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 400.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)